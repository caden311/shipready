---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  ogImage?: string;
}

const { title, description, canonicalURL, ogImage } = Astro.props;
const siteUrl = 'https://vientapps.com';
const resolvedCanonical = canonicalURL || new URL(Astro.url.pathname, siteUrl).toString();
const resolvedOgImage = ogImage || new URL('/tools/seo-check/og-shipready.png', siteUrl).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0a0a0b" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={resolvedCanonical} />
    <link rel="icon" type="image/svg+xml" href="/tools/seo-check/favicon.svg" />

    <!-- Prevent FOUC -->
    <script is:inline>
      (function(){
        var s=null;
        try{s=localStorage.getItem('vientapps:theme')}catch(e){}
        if(s!=='light'&&s!=='dark')s=matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light';
        document.documentElement.setAttribute('data-theme',s);
        try{localStorage.setItem('vientapps:theme',s)}catch(e){}
        var m=document.querySelector('meta[name="theme-color"]');
        if(m)m.content=s==='dark'?'#0a0a0b':'#f9f9f7'
      })()
    </script>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Vient Apps" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      />
    </noscript>

    <slot name="head" />
  </head>
  <body class="min-h-screen bg-bg text-ink antialiased">
    <header class="border-b border-line bg-bg-2/85 backdrop-blur-sm">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6">
        <a href="https://vientapps.com" class="flex items-center gap-2 text-ink hover:text-accent transition-colors">
          <span class="font-display text-xl font-bold">VientApps</span>
        </a>
        <div class="flex items-center gap-3">
          <a
            href="https://vientapps.com/tools/"
            class="text-sm text-ink-3 hover:text-accent transition-colors"
          >
            More Tools
          </a>
          <ThemeToggle />
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-auto border-t border-line bg-bg-2/50">
      <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6">
        <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
          <p class="text-sm text-ink-3">
            Built by <a href="https://vientapps.com" class="text-accent hover:text-accent transition-colors">Vient Apps</a>
          </p>
          <div class="flex gap-6 text-sm text-ink-3">
            <a href="https://vientapps.com/tools/" class="hover:text-ink-2 transition-colors">All Tools</a>
            <a href="https://vientapps.com/blog/" class="hover:text-ink-2 transition-colors">Blog</a>
          </div>
        </div>
      </div>
    </footer>
    <script src="https://vientapps.com/scripts/track.js" defer></script>
  </body>
</html>
