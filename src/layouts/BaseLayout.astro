---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  ogImage?: string;
}

const { title, description, canonicalURL, ogImage } = Astro.props;
const siteUrl = 'https://vientapps.com';
const resolvedCanonical = canonicalURL || new URL(Astro.url.pathname, siteUrl).toString();
const resolvedOgImage = ogImage || new URL('/tools/seo-check/og-shipready.png', siteUrl).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0a0a0b" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={resolvedCanonical} />
    <link rel="icon" type="image/svg+xml" href="/tools/seo-check/favicon.svg" />

    <!-- Prevent FOUC -->
    <script is:inline>
      (function(){
        var s=null;
        try{s=localStorage.getItem('vientapps:theme')}catch(e){}
        if(s!=='light'&&s!=='dark')s=matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light';
        document.documentElement.setAttribute('data-theme',s);
        try{localStorage.setItem('vientapps:theme',s)}catch(e){}
        var m=document.querySelector('meta[name="theme-color"]');
        if(m)m.content=s==='dark'?'#0a0a0b':'#f9f9f7'
      })()
    </script>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Vient Apps" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      />
    </noscript>

    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col bg-bg text-ink antialiased">
    <Header />

    <main class="flex-1">
      <slot />
    </main>

    <Footer />
    <script src="https://vientapps.com/scripts/track.js" defer></script>
  </body>
</html>
